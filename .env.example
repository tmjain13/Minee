# ─── FIREBASE CONFIGURATION ───
# Get these from Firebase Console → Project Settings → General → Your apps → SDK setup and configuration
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# ─── SENTRY ERROR MONITORING ───
# Get DSN from: https://sentry.io/settings/projects/terapanth-ai-hub/keys/
# Create account at sentry.io → New Project → React → Copy DSN
# Leave empty to disable Sentry (dev mode)
VITE_SENTRY_DSN=""

# ─── APP VERSION ───
# Auto-set during build from package.json, override if needed
VITE_APP_VERSION="1.0.0"

# ─── GEMINI API (Server-side only, not used in client) ───
# GEMINI_API_KEY=""  # Set in server .env, NOT here
