{
  "name": "terapanth-ai-hub",
  "version": "1.0.0",
  "description": "Unified Knowledge & Sadhana Platform for Terapanth",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "tsc && vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "preview": "vite preview",
    "analyze": "ANALYZE=true vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test:rules": "firebase emulators:exec --only firestore 'jest --testPathPattern=firestore.rules.test.ts'",
    "test:watch": "jest --watch",
    "emulators:start": "firebase emulators:start --only firestore",
    "emulators:stop": "lsof -ti:8080,8085,4000 | xargs kill -9 || true",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@sentry/react": "^10.65.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/canvas-confetti": "^1.9.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@xenova/transformers": "^2.17.2",
    "autoprefixer": "^10.4.21",
    "axios": "^1.16.1",
    "canvas-confetti": "^1.9.4",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "esbuild": "^0.25.12",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "firebase": "^11.1.0",
    "firebase-admin": "^13.10.0",
    "helmet": "^8.2.0",
    "html2canvas": "^1.4.1",
    "ics": "^3.12.0",
    "idb": "^8.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "suncalc": "^1.9.0",
    "tailwindcss": "^4.1.14",
    "vite": "^6.2.3",
    "workbox-window": "^7.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@sentry/vite-plugin": "^5.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.6",
    "@types/suncalc": "^1.9.2",
    "eslint": "^10.5.0",
    "firebase-tools": "^15.23.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "ts-jest": "^29.4.11",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0"
  }
}
